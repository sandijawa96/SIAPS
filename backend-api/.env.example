APP_NAME="Sistem Absensi Sekolah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ATTENDANCE_QR_ENABLED=false
ATTENDANCE_FACE_ENABLED=true
ATTENDANCE_FACE_TEMPLATE_REQUIRED=true
ATTENDANCE_FACE_MODE_DEFAULT=async_pending
ATTENDANCE_FACE_QUEUE=face-verification
ATTENDANCE_FACE_THRESHOLD=0.363
ATTENDANCE_FACE_ENGINE_VERSION=opencv-yunet-sface-v1
ATTENDANCE_FACE_TEMPLATE_MISSING_RESULT=verified
ATTENDANCE_FACE_REJECT_TO_REVIEW=true
ATTENDANCE_FACE_SKIP_WHEN_PHOTO_MISSING=true
ATTENDANCE_FACE_SERVICE_URL=http://127.0.0.1:9001
ATTENDANCE_FACE_SERVICE_TOKEN=
ATTENDANCE_FACE_SERVICE_CONNECT_TIMEOUT=1.5
ATTENDANCE_FACE_SERVICE_REQUEST_TIMEOUT=5.0
ATTENDANCE_AUTO_ALPHA_ENABLED=true
ATTENDANCE_AUTO_ALPHA_RUN_TIME=23:50
ATTENDANCE_DISCIPLINE_ALERTS_ENABLED=true
ATTENDANCE_DISCIPLINE_ALERTS_RUN_TIME=23:57
LIVE_TRACKING_RETENTION_DAYS=30
LIVE_TRACKING_CLEANUP_TIME=02:15
ATTENDANCE_GPS_ACCURACY_GRACE_METERS=0

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=absensi_sekolah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
BROADCAST_NOTIFICATION_QUEUE=broadcast
BROADCAST_NOTIFICATION_CHUNK_SIZE=200
BROADCAST_WHATSAPP_QUEUE=broadcast-whatsapp
BROADCAST_WHATSAPP_CHUNK_SIZE=50
BROADCAST_EMAIL_QUEUE=broadcast-email
BROADCAST_EMAIL_CHUNK_SIZE=100

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
JWT_SECRET=
JWT_TTL=10080
JWT_REFRESH_TTL=20160

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@absensi-sekolah.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1

# WhatsApp Gateway Configuration
WHATSAPP_API_URL=https://your-wa-gateway.example.com
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_TIMEOUT=20
WHATSAPP_RETRY_TIMES=2
WHATSAPP_RETRY_SLEEP_MS=300
WHATSAPP_AUTO_RETRY_ENABLED=true
WHATSAPP_AUTO_RETRY_BATCH_SIZE=100
WHATSAPP_AUTO_RETRY_COOLDOWN_SECONDS=300

# GPS Configuration
GPS_RADIUS_METERS=100
SCHOOL_LATITUDE=-6.2088
SCHOOL_LONGITUDE=106.8456
SCHOOL_NAME="SMA Negeri 1 Jakarta"
SCHOOL_ADDRESS="Jl. Budi Kemuliaan I No.2, Gambir, Jakarta Pusat"

# Attendance Anti-Fraud Rollout
# Salin baseline yang lebih lengkap dari backend-api/.env.attendance-fraud.example saat siap rollout produksi.
ATTENDANCE_SECURITY_EVENT_LOGGING_ENABLED=true
ATTENDANCE_SECURITY_ROLLOUT_MODE=warning_mode
ATTENDANCE_SECURITY_WARN_USER=true
ATTENDANCE_SECURITY_STORE_RAW_PAYLOAD=true
ATTENDANCE_SECURITY_TIMESTAMP_TOLERANCE_SECONDS=180
ATTENDANCE_SECURITY_NONCE_TTL_SECONDS=300
ATTENDANCE_SECURITY_DUPLICATE_WINDOW_SECONDS=10
ATTENDANCE_SECURITY_STALE_LOCATION_SECONDS=120
ATTENDANCE_SECURITY_TIME_DRIFT_WARNING_SECONDS=90
ATTENDANCE_SECURITY_TIME_DRIFT_REJECT_SECONDS=300
ATTENDANCE_SECURITY_IMPOSSIBLE_TRAVEL_SPEED_KMH=300
ATTENDANCE_SECURITY_DUPLICATE_COORDINATE_WINDOW_DAYS=7
ATTENDANCE_SECURITY_DUPLICATE_COORDINATE_LIMIT=5
ATTENDANCE_SECURITY_EXPECTED_ANDROID_PACKAGE=id.sch.sman1sumbercirebon.siaps
ATTENDANCE_SECURITY_EXPECTED_IOS_BUNDLE=
ATTENDANCE_SECURITY_ALLOWED_INSTALLERS=com.android.vending,com.google.android.packageinstaller,com.miui.packageinstaller
ATTENDANCE_SECURITY_REQUEST_SIGNING_ENABLED=false
ATTENDANCE_SECURITY_REQUEST_SIGNING_KEY=
ATTENDANCE_SECURITY_REQUEST_SIGNING_MAX_AGE_SECONDS=180
ATTENDANCE_SECURITY_WARNING_SCORE=25
ATTENDANCE_SECURITY_MANUAL_REVIEW_SCORE=50
ATTENDANCE_SECURITY_REJECT_SCORE=80
ATTENDANCE_SECURITY_CRITICAL_SCORE=100

# File Upload Configuration
MAX_FILE_SIZE=10240
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xls,xlsx

# Nextcloud Storage Configuration
NEXTCLOUD_ENABLED=false
NEXTCLOUD_BASE_URL=https://cloud.sekolah.sch.id
NEXTCLOUD_WEBDAV_BASE_URL=
NEXTCLOUD_PUBLIC_BASE_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_ROOT_PATH=SIAPS
NEXTCLOUD_TIMEOUT=30

# Backup Configuration
BACKUP_DISK=local
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# QR Code Configuration
QR_CODE_SIZE=300
QR_CODE_FORMAT=png
QR_CODE_ERROR_CORRECTION=M

# Notification Configuration
NOTIFICATION_CHANNELS=database,mail,whatsapp
NOTIFICATION_QUEUE=default

# Push Notification Configuration
PUSH_ENABLED=false
PUSH_PROVIDER=fcm
FCM_ENDPOINT=
FCM_ANDROID_CHANNEL_ID=siaps_notifications
FCM_SERVICE_ACCOUNT_JSON=storage/app/firebase/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-firebase-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
FIREBASE_VAPID_KEY=your-firebase-vapid-key

# Security Configuration
PASSWORD_MIN_LENGTH=8
SESSION_SECURE_COOKIE=false
CSRF_COOKIE_SECURE=false

# API Configuration
API_RATE_LIMIT=60
API_THROTTLE_REQUESTS=1000
API_THROTTLE_MINUTES=1

# Development Configuration
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
