{
  "short_name": "SIAP Absensi",
  "name": "Sistem Informasi Absensi Pembelajaran",
  "description": "Aplikasi manajemen absensi pembelajaran yang efisien dan terintegrasi",
  "icons": [
    {
      "src": "icon.png",
      "sizes": "64x64 128x128 192x192 256x256 512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "logo192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "logo512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "start_url": ".",
  "display": "standalone",
  "theme_color": "#3B82F6",
  "background_color": "#ffffff",
  "orientation": "portrait",
  "categories": ["education", "productivity"],
  "shortcuts": [
    {
      "name": "Absensi QR Code",
      "short_name": "QR Code",
      "description": "Scan QR Code untuk absensi",
      "url": "/absensi-qr-code",
      "icons": [{ "src": "logo192.png", "sizes": "192x192" }]
    },
    {
      "name": "Absensi Selfie",
      "short_name": "Selfie",
      "description": "Absensi dengan foto selfie",
      "url": "/absensi-selfie",
      "icons": [{ "src": "logo192.png", "sizes": "192x192" }]
    }
  ],
  "screenshots": [
    {
      "src": "screenshot1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Dashboard SIAP Absensi"
    },
    {
      "src": "screenshot2.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Manajemen Data Siswa"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "features": [
    "Absensi QR Code",
    "Absensi Selfie",
    "Manajemen Data Siswa & Pegawai",
    "Laporan Real-time",
    "Notifikasi WhatsApp"
  ],
  "dir": "ltr",
  "lang": "id",
  "scope": "/",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "iarc_rating_id": "",
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", ".pdf"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+siapabsensi",
      "url": "/%s"
    }
  ],
  "permissions": [
    "geolocation",
    "camera",
    "notifications",
    "background-sync"
  ],
  "serviceworker": {
    "src": "/sw.js",
    "scope": "/",
    "use_cache": true,
    "update_via_cache": "none"
  },
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  }
}
