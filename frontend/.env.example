# API Configuration
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_APP_NAME=Sistem Absensi
REACT_APP_VERSION=1.0.0

# Development Settings
REACT_APP_DEBUG=true
REACT_APP_LOG_LEVEL=debug

# Feature Flags
REACT_APP_ENABLE_FACE_DETECTION=true
REACT_APP_ENABLE_GPS_VERIFICATION=true
REACT_APP_ENABLE_WHATSAPP_NOTIFICATIONS=true
VITE_ATTENDANCE_QR_ENABLED=false
VITE_API_BASE_URL=https://load.sman1sumbercirebon.sch.id/api
VITE_LIVE_TRACKING_TEST_ROUTE_ENABLED=false

# Live Tracking Map Overlay (Opsional)
VITE_TRAFFIC_TILE_URL=
VITE_TRAFFIC_TILE_ATTRIBUTION=

# Map Configuration (if using maps)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# File Upload Settings
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Session Settings
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_REMEMBER_ME_DURATION=2592000000
